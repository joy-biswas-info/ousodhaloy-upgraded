APP_NAME="Ousodhaloy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Dhaka
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ousodhaloy
DB_USERNAME=root
DB_PASSWORD=

# SQLite alternative (for quick local dev):
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@ousodhaloy.com"
MAIL_FROM_NAME="Ousodhaloy"

# ── SSL Commerz ─────────────────────────────────────
# Get credentials: https://developer.sslcommerz.com/registration/
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWD=your_store_password
SSLCOMMERZ_IS_LIVE=false
# SSLCOMMERZ_IS_LIVE=true   ← for production

# ── Pathao Courier ──────────────────────────────────
# Get credentials: https://merchant.pathao.com/api-information
PATHAO_CLIENT_ID=your_client_id
PATHAO_CLIENT_SECRET=your_client_secret
PATHAO_USERNAME=your_username
PATHAO_PASSWORD=your_password
PATHAO_IS_LIVE=false
# PATHAO_IS_LIVE=true   ← for production

# ── MimSMS ──────────────────────────────────────────
# Dashboard: https://app.mimsms.com/
MIMSMS_API_KEY=your_api_key
MIMSMS_SENDER_ID=Ousodhaloy

# ── bKash (optional — via SSL Commerz or direct) ────
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_IS_SANDBOX=true

# ── AWS S3 (optional media storage) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── App-specific ─────────────────────────────────────
FREE_DELIVERY_MIN=500
DELIVERY_CHARGE=0
GUEST_CHECKOUT=true
SMS_ORDER_CONFIRM=true
SMS_STATUS_UPDATE=true
OTP_EXPIRY_MINUTES=5
